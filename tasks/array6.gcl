//Array assignment in if fi
> A = [0,1,0]
if A[1] < 3 ->
    A[0] := 2
fi;

if A[0] = 2 ->
    A[2] := 3
[] A[2] = 0 ->
    A[0] := 1
fi

check A[0] = 0 & A[1] = 1 & A[2] = 0
check F (A[0] = 2 & A[1] = 1 & A[2] = 0)
check X X X X ((A[0] = 1 & A[2] = 0) | (A[0] = 2 & A[2] = 3))
check G A[1] = 1
check F terminated
